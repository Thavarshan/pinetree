# Local development defaults. Copy .env.example for real values.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/pinetree?schema=public
TIMEZONE="Asia/Colombo"
PORT=3000
# Set these to run the webhook fully:
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

PUBLIC_BASE_URL=https://example.com
ADMIN_API_KEY=changeme

# ---- Dashboard (apps/dashboard/.env) ----------------------------------------
# Copy apps/dashboard/.env.example → apps/dashboard/.env and set these values.
# VITE_ADMIN_USERNAME=admin
# VITE_ADMIN_PASSWORD=changeme        # must match a secret you choose
# VITE_API_KEY=changeme               # must equal ADMIN_API_KEY above
