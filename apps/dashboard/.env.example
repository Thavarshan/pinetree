# Dashboard environment variables.
# Copy this file to .env and fill in real values.

# The base URL of the API. Leave blank when using the Vite dev-server proxy.
VITE_API_BASE_URL=

# Credentials that protect the dashboard login screen.
# These are evaluated client-side; keep this file out of public repositories.
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=changeme

# API key forwarded to the backend on every request (must match ADMIN_API_KEY in the API .env).
VITE_API_KEY=changeme
