generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  provider       String
  providerUserId String
  name           String
  avatarUrl      String?
  createdAt      DateTime @default(now())

  events          Event[]
  supplyRequests  SupplyRequest[]
  concerns        Concern[]
  crewOffRequests CrewOffRequest[]

  @@unique([provider, providerUserId])
}

model Chat {
  id             String   @id @default(cuid())
  provider       String
  providerChatId String
  name           String?
  createdAt      DateTime @default(now())

  events          Event[]
  supplyRequests  SupplyRequest[]
  concerns        Concern[]
  crewOffRequests CrewOffRequest[]

  @@unique([provider, providerChatId])
}

model Event {
  id              String   @id @default(cuid())
  chatId          String
  userId          String
  eventType       String
  text            String?
  mediaUrl        String?
  mediaType       String?
  transcript      String?
  sourceMessageId String   @unique
  rawPayload      String?
  createdAt       DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@index([userId, createdAt])
}

model SupplyRequest {
  id             String   @id @default(cuid())
  userId         String
  chatId         String
  clientLocation String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Concern {
  id             String   @id @default(cuid())
  userId         String
  chatId         String
  text           String
  conversationId String
  provider       String
  status         String   @default("OPEN")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CrewOffRequest {
  id        String   @id @default(cuid())
  userId    String
  chatId    String
  text      String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
